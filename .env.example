# ──────────────────────────────────────────────────────────────────────────────
# Triple J Metal — env template
# Copy to `.env.local` and fill in. `.env.local` is git-ignored.
# Vercel Production reads from its own dashboard, not this file.
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# From supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOi..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi..."
# ⚠️  service_role is admin-level, never expose client-side

# ── Site URL ──────────────────────────────────────────────────────────────────
# Used to build quote accept links. No trailing slash.
# Local: http://localhost:3000 · Production: https://triplejmetaltx.com
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Resend (outbound email) ───────────────────────────────────────────────────
# From resend.com → API Keys. Domain `triplejmetaltx.com` must be verified.
RESEND_API_KEY="re_..."
# From resend.com → Webhooks → endpoint signing secret
RESEND_WEBHOOK_SECRET="whsec_..."

# ── Owner alert recipient ─────────────────────────────────────────────────────
# Where new-lead + quote-accepted alerts are sent.
# Comma-separated, no spaces, for multiple recipients.
OWNER_EMAIL="julianleon@triplejmetaltx.com"

# ── QuickBooks Online ─────────────────────────────────────────────────────────
# From developer.intuit.com → your app → Keys & OAuth
QBO_CLIENT_ID=""
QBO_CLIENT_SECRET=""
QBO_REDIRECT_URI="http://localhost:3000/api/qbo/callback"
# Local: use the localhost redirect above · Production: https://triplejmetaltx.com/api/qbo/callback
# "sandbox" while testing against developer-sandbox QBO; "production" once the
# Intuit app is approved for production.
QBO_ENVIRONMENT="sandbox"

# ── Permit scrape cron ────────────────────────────────────────────────────────
# Shared secret the daily Vercel Cron uses to hit /api/cron/scrape-permits.
# Generate any random string, e.g. `openssl rand -hex 32`.
CRON_SECRET=""

# ── Web Push (B4 — owner device notifications) ───────────────────────────────
# Generate once with: npx web-push generate-vapid-keys
# Paste public key into BOTH VAPID_PUBLIC_KEY and NEXT_PUBLIC_VAPID_PUBLIC_KEY.
# VAPID_SUBJECT is the contact URL Apple/Google use if they need to reach you.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:julianleon@triplejmetaltx.com"

# ── Google Maps (HQ job-detail map hero) ─────────────────────────────────────
# Server-only — used to render Static Maps images for job addresses.
# Enable "Maps Static API" at console.cloud.google.com. If blank, the HQ Job
# detail page falls back to a typography-only address card (no broken image).
GOOGLE_MAPS_STATIC_KEY=""

# ── hCaptcha (form spam protection) ──────────────────────────────────────────
# Sign up at hcaptcha.com — free for unlimited verifications. Site key is
# public (rendered in the widget HTML). Secret is server-side only.
# In dev: leave HCAPTCHA_SECRET_KEY blank to skip captcha verification —
# /api/leads + /api/partner-inquiries POSTs will succeed without a token.
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=""
HCAPTCHA_SECRET_KEY=""

# ── OpenAI (voice memo → lead transcription) ─────────────────────────────────
# Phase 4: hold the + button in HQ → MediaRecorder → /api/hq/voice-lead →
# OpenAI Whisper transcribes the audio → Claude Sonnet 4.6 extracts
# {name, phone, zip, service_type, …} → leads insert with source='voice_memo'.
# Cost: ~$0.006/min = $0.30/mo at ~100 memos. From platform.openai.com → API keys.
# If blank, /api/hq/voice-lead returns a 503 explaining setup.
# ⚠️  Production currently has this misnamed as OPEN_API_KEY. Fix:
#     vercel env rm OPEN_API_KEY production preview
#     vercel env add OPENAI_API_KEY production preview
OPENAI_API_KEY=""

# ── Anthropic (Claude — receipt OCR + permit extraction) ─────────────────────
# Receipt OCR (/api/hq/receipt → vendor/total/line items) and the daily
# permit-leads scrape (/api/cron/scrape-permits → Bell County PDFs) both
# call Claude. From console.anthropic.com → API Keys.
# If blank, the receipt + permit features 503; the rest of the app works.
ANTHROPIC_API_KEY=""

# ── Meta / Facebook lead-ad webhook ──────────────────────────────────────────
# Inbound: Meta posts new lead-ad submissions to /api/webhooks/facebook.
# - META_APP_SECRET — from developers.facebook.com → your app, used to verify
#   the X-Hub-Signature-256 header on every POST.
# - META_PAGE_ACCESS_TOKEN — long-lived page token (Graph API Explorer).
# - META_VERIFY_TOKEN — any random string; paste the same value into Meta's
#   webhook subscription page so the GET handshake passes.
# Note: the Vercel project also has META_APP_ID set, but code doesn't read it.
# Safe to remove from Vercel, or leave for documentation purposes.
# If blank, the webhook GET handshake fails and the POST signature check
# rejects every payload — Messenger leads stop flowing in.
META_APP_SECRET=""
META_PAGE_ACCESS_TOKEN=""
META_VERIFY_TOKEN=""

# ── Twilio (outbound SMS for quote send) ─────────────────────────────────────
# /api/quotes/[id]/send-sms uses these to text the customer the quote-accept
# link. Sign up at twilio.com, buy a local 254 number for ~$1/mo + $0.0079/SMS.
# TWILIO_FROM_NUMBER must be E.164 (e.g. +12543467764).
# If blank, the Send SMS button on /hq/quotes/[id] returns 503 with a hint.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# ── Setup gate (one-time bootstrap) ──────────────────────────────────────────
# Shared secret protecting POST /api/setup, which seeds the initial admin
# user + base data. Generate any random string, e.g. `openssl rand -hex 24`.
# Only required for first-time setup on a fresh Supabase project; rotate or
# remove after bootstrap is done.
SETUP_KEY=""
