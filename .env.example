# ──────────────────────────────────────────────────────────────────────────────
# Triple J Metal — env template
# Copy to `.env.local` and fill in. `.env.local` is git-ignored.
# Vercel Production reads from its own dashboard, not this file.
#
# Legend:
#   [REQUIRED] site/HQ won't function without it
#   [OPTIONAL] feature stays gracefully disabled until configured
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# [REQUIRED] From supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOi..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi..."
# ⚠️  service_role is admin-level, never expose client-side

# ── Site URL ──────────────────────────────────────────────────────────────────
# [REQUIRED] Used to build quote accept links + SMS deep links. No trailing slash.
# Local: http://localhost:3000 · Production: https://triplejmetaltx.com
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Resend (outbound email) ───────────────────────────────────────────────────
# [REQUIRED] From resend.com → API Keys. Domain `triplejmetaltx.com` must be verified.
RESEND_API_KEY="re_..."
# [REQUIRED] From resend.com → Webhooks → endpoint signing secret
RESEND_WEBHOOK_SECRET="whsec_..."

# ── Owner alert recipient ─────────────────────────────────────────────────────
# [REQUIRED] Where new-lead + quote-accepted alerts are sent.
# Comma-separated, no spaces, for multiple recipients.
OWNER_EMAIL="julianleon@triplejmetaltx.com"

# ── Twilio (SMS — speed-to-response, review ask, quote send) ─────────────────
# [OPTIONAL] All three must be set or the SMS layer no-ops silently.
# When configured, these endpoints start shipping SMS without code changes:
#   - POST /api/leads          → 60-sec auto-reply to new leads (Phase 2.A)
#   - POST /api/customers/[id]/review action=asked → review-ask SMS (Phase 2.B)
#   - POST /api/quotes/[id]/send-sms                → quote summary + accept link
# Provision: twilio.com → Console → Account info (SID + auth token) → Phone
# Numbers → buy a US local number → drop in TWILIO_FROM_NUMBER as +1XXXXXXXXXX.
# Cost: ~$1.15/mo number rental + $0.0079/SMS (≈$25/mo at projected lead volume).
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# ── Google review link (post-job review-ask SMS body) ────────────────────────
# [OPTIONAL] The GBP "leave a review" deep link. Without it, the review-ask
# SMS still sends but with a generic "search Triple J Metal on Google" line.
# Get it from business.google.com → Reviews → Get more reviews → copy the URL
# (looks like https://g.page/r/CXXXXXXXXXXXXXXX/review).
GOOGLE_REVIEW_URL=""

# ── QuickBooks Online ─────────────────────────────────────────────────────────
# [OPTIONAL] From developer.intuit.com → your app → Keys & OAuth
QBO_CLIENT_ID=""
QBO_CLIENT_SECRET=""
QBO_REDIRECT_URI="http://localhost:3000/api/qbo/callback"
# Local: use the localhost redirect above · Production: https://triplejmetaltx.com/api/qbo/callback
# QBO_ENVIRONMENT toggles which Intuit API the app talks to:
#   - "sandbox"    → developer test company (no real books touched)
#   - "production" → real Triple J Metal books — flip only after sandbox is wired.
QBO_ENVIRONMENT="sandbox"

# ── Permit scrape cron ────────────────────────────────────────────────────────
# [OPTIONAL — required if Vercel Cron is enabled] Shared secret the daily
# Vercel Cron uses to hit /api/cron/scrape-permits and /api/cron/review-followups.
# Generate any random string, e.g. `openssl rand -hex 32`.
CRON_SECRET=""

# ── Setup key (one-time admin seed endpoint) ─────────────────────────────────
# [OPTIONAL] Bearer token for /api/setup. Used once during initial deploy
# to seed the first admin user; can be left blank or rotated after.
# Generate with `openssl rand -hex 32`.
SETUP_KEY=""

# ── Web Push (B4 — owner device notifications) ───────────────────────────────
# [OPTIONAL] Generate once with: npx web-push generate-vapid-keys
# Paste public key into NEXT_PUBLIC_VAPID_PUBLIC_KEY (the only one the code reads).
# VAPID_SUBJECT is the contact URL Apple/Google use if they need to reach you.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:julianleon@triplejmetaltx.com"

# ── Google Maps (HQ job-detail map hero) ─────────────────────────────────────
# [OPTIONAL] Server-only — used to render Static Maps images for job addresses.
# Enable "Maps Static API" at console.cloud.google.com. If blank, the HQ Job
# detail page falls back to a typography-only address card (no broken image).
GOOGLE_MAPS_STATIC_KEY=""

# ── hCaptcha (form spam protection) ──────────────────────────────────────────
# [OPTIONAL in dev / REQUIRED in prod] Sign up at hcaptcha.com — free for
# unlimited verifications. Site key is public (rendered in the widget HTML).
# Secret is server-side only.
# In dev: leave HCAPTCHA_SECRET_KEY blank to skip captcha verification —
# /api/leads + /api/partner-inquiries POSTs will succeed without a token.
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=""
HCAPTCHA_SECRET_KEY=""

# ── OpenAI (voice memo → lead transcription) ─────────────────────────────────
# [OPTIONAL] Phase 4: hold the + button in HQ → MediaRecorder → /api/hq/voice-lead →
# OpenAI Whisper transcribes the audio. Claude Sonnet (see ANTHROPIC_API_KEY
# below) then extracts {name, phone, zip, service_type, …} for the leads insert.
# Cost: ~$0.006/min = $0.30/mo at ~100 memos. From platform.openai.com → API keys.
# If blank, /api/hq/voice-lead returns a 503 explaining setup.
OPENAI_API_KEY=""

# ── Anthropic (Claude — voice/receipt/permit structured extraction) ──────────
# [OPTIONAL] Used by:
#   - src/lib/voice-lead-extractor.ts  → voice-memo transcript → structured lead
#   - src/lib/receipt-extractor.ts     → receipt photo → vendor/total/category
#   - src/lib/permit-extractor.ts      → scraped permit blob → contact + scope
# Cost: ~$0.001-0.005 per call (Sonnet 4.6 vision). From console.anthropic.com.
# If blank, the three features above 503 with a setup hint; nothing else breaks.
ANTHROPIC_API_KEY=""

# ── Meta (Facebook Lead Ads + Messenger DMs → /api/webhooks/facebook) ────────
# [OPTIONAL] Wires FB Lead Ads form submissions and Page Messenger DMs into
# the leads table (source='facebook_lead_ads' or 'facebook_messenger').
# Setup walkthrough: developers.facebook.com → your app → Webhooks subscription.
#   - META_VERIFY_TOKEN     — any random string; you choose it, paste the same
#                             one into the Meta dashboard's webhook setup.
#   - META_APP_SECRET       — App Settings → Basic → App Secret (used to verify
#                             X-Hub-Signature-256 on incoming POSTs).
#   - META_PAGE_ACCESS_TOKEN — long-lived Page token from Graph API Explorer.
META_VERIFY_TOKEN=""
META_APP_SECRET=""
META_PAGE_ACCESS_TOKEN=""
