# ──────────────────────────────────────────────────────────────────────────────
# Triple J Metal — env template
# Copy to `.env.local` and fill in. `.env.local` is git-ignored.
# Vercel Production reads from its own dashboard, not this file.
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# From supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOi..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi..."
# ⚠️  service_role is admin-level, never expose client-side

# ── Site URL ──────────────────────────────────────────────────────────────────
# Used to build quote accept links. No trailing slash.
# Local: http://localhost:3000 · Production: https://triplejmetaltx.com
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Resend (outbound email) ───────────────────────────────────────────────────
# From resend.com → API Keys. Domain `triplejmetaltx.com` must be verified.
RESEND_API_KEY="re_..."
# From resend.com → Webhooks → endpoint signing secret
RESEND_WEBHOOK_SECRET="whsec_..."

# ── Owner alert recipient ─────────────────────────────────────────────────────
# Where new-lead + quote-accepted alerts are sent.
# Comma-separated, no spaces, for multiple recipients.
OWNER_EMAIL="julianleon@triplejmetaltx.com"

# ── QuickBooks Online ─────────────────────────────────────────────────────────
# From developer.intuit.com → your app → Keys & OAuth
QBO_CLIENT_ID=""
QBO_CLIENT_SECRET=""
QBO_REDIRECT_URI="http://localhost:3000/api/qbo/callback"
# Local: use the localhost redirect above · Production: https://triplejmetaltx.com/api/qbo/callback

# ── Permit scrape cron ────────────────────────────────────────────────────────
# Shared secret the daily Vercel Cron uses to hit /api/cron/scrape-permits.
# Generate any random string, e.g. `openssl rand -hex 32`.
CRON_SECRET=""

# ── Web Push (B4 — owner device notifications) ───────────────────────────────
# Generate once with: npx web-push generate-vapid-keys
# Paste public key into BOTH VAPID_PUBLIC_KEY and NEXT_PUBLIC_VAPID_PUBLIC_KEY.
# VAPID_SUBJECT is the contact URL Apple/Google use if they need to reach you.
VAPID_PUBLIC_KEY=""
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:julianleon@triplejmetaltx.com"
